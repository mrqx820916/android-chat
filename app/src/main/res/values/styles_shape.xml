<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 圆形ImageView样式 -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- 圆角卡片样式 -->
    <style name="RoundedCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_medium</item>
        <item name="cardElevation">@dimen/elevation_small</item>
    </style>

    <!-- 圆角按钮样式 -->
    <style name="RoundedButton" parent="Widget.Material3.Button">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_medium</item>
    </style>
</resources>
